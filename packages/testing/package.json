{
  "name": "@domglyph/testing",
  "version": "2.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@domglyph/ai-contract": "workspace:*",
    "@domglyph/components": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
